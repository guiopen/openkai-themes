    "diffRemoved": {
      "dark": "red",
      "light": "lightRed"
    },
    "diffContext": {
      "dark": "comment",
      "light": "lightComment"
    },
    "diffHunkHeader": {
      "dark": "comment",
      "light": "lightComment"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "lightGreen"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "lightRed"
    },
    "diffAddedBg": {
      "dark": "diffAddedBg",
      "light": "lightDiffAddedBg"
    },
    "diffRemovedBg": {
      "dark": "diffRemovedBg",
      "light": "lightDiffRemovedBg"
    },
    "diffContextBg": {
      "dark": "backgroundAlt",
      "light": "lightBackgroundAlt"
    },
    "diffLineNumber": {
      "dark": "dim",
      "light": "lightDim"
    },
    "diffAddedLineNumberBg": {
      "dark": "diffAddedBg",
      "light": "lightDiffAddedBg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diffRemovedBg",
      "light": "lightDiffRemovedBg"
    },
    "markdownText": {
      "dark": "foreground",
      "light": "lightForeground"
    },
    "markdownHeading": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "markdownLink": {
      "dark": "green",
      "light": "lightGreen"
    },
    "markdownLinkText": {
      "dark": "red",
      "light": "lightRed"
    },
    "markdownCode": {
      "dark": "green",
      "light": "lightGreen"
    },
    "markdownBlockQuote": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "markdownStrong": {
      "dark": "orange",
      "light": "lightOrange"
    },
    "markdownHorizontalRule": {
      "dark": "comment",
      "light": "lightComment"
    },
    "markdownListItem": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "markdownListEnumeration": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "markdownImage": {
      "dark": "green",
      "light": "lightGreen"
    },
    "markdownImageText": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "markdownCodeBlock": {
      "dark": "foreground",
      "light": "lightForeground"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "lightComment"
    },
    "syntaxKeyword": {
      "dark": "red",
      "light": "lightRed"
    },
    "syntaxFunction": {
      "dark": "green",
      "light": "lightGreen"
    },
    "syntaxVariable": {
      "dark": "foreground",
      "light": "lightForeground"
    },
    "syntaxString": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "syntaxNumber": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "syntaxType": {
      "dark": "cyan",
      "light": "lightCyan"
    },
    "syntaxOperator": {
      "dark": "red",
      "light": "lightRed"
    },
    "syntaxPunctuation": {
      "dark": "muted",
      "light": "lightMuted"
    }
