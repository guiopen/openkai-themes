  "theme": {
    "primary": {
      "dark": "gray",
      "light": "lightGray"
    },
    "secondary": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "accent": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "error": {
      "dark": "red",
      "light": "lightRed"
    },
    "warning": {
      "dark": "orange",
      "light": "lightOrange"
    },
    "success": {
      "dark": "green",
      "light": "lightGreen"
    },
    "info": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "text": {
      "dark": "foreground",
      "light": "lightForeground"
    },
    "textMuted": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "background": {
      "dark": "background",
      "light": "lightBackground"
    },
    "backgroundPanel": {
      "dark": "backgroundAlt",
      "light": "lightBackgroundAlt"
    },
    "backgroundElement": {
      "dark": "backgroundPanel",
      "light": "lightBackgroundPanel"
    },
    "border": {
      "dark": "border",
      "light": "lightBorder"
    },
    "borderActive": {
      "dark": "borderFocus",
      "light": "lightBorderFocus"
    },
    "borderSubtle": {
      "dark": "borderSubtle",
      "light": "lightBorderSubtle"
    },
    "diffAdded": {
      "dark": "green",
      "light": "lightGreen"
