{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "background": "#2c2525",
    "backgroundAlt": "#251f1f",
    "backgroundPanel": "#403838",
    "foreground": "#fff1f3",
    "comment": "#72696a",
    "muted": "#948a8b",
    "dim": "#5b5353",
    "gray": "#c3b7b8",
    "red": "#fd6883",
    "orange": "#f38d70",
    "yellow": "#f9cc6c",
    "green": "#adda78",
    "cyan": "#85dacc",
    "purple": "#a8a9eb",
    "border": "#171414",
    "borderFocus": "#72696a",
    "borderSubtle": "#191515",
    "diffAddedBg": "#3c3b2f",
    "diffRemovedBg": "#452d30",
    "lightBackground": "#f8efe7",
    "lightBackgroundAlt": "#ece5df",
    "lightBackgroundPanel": "#ded5d0",
    "lightForeground": "#2c232e",
    "lightComment": "#a59c9c",
    "lightMuted": "#92898a",
    "lightDim": "#beb5b3",
    "lightGray": "#72696d",
    "lightRed": "#ce4770",
    "lightOrange": "#d4572b",
    "lightYellow": "#b16803",
    "lightGreen": "#218871",
    "lightCyan": "#2473b6",
    "lightPurple": "#6851a2",
    "lightBorder": "#ccc5bf",
    "lightBorderFocus": "#a59c9c",
    "lightBorderSubtle": "#ded5d0",
    "lightDiffAddedBg": "#cdd6cc",
    "lightDiffRemovedBg": "#f1d4d4"
