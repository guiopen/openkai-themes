      "dark": "foreground",
      "light": "lightForeground"
    },
    "markdownHeading": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "markdownLink": {
      "dark": "green",
      "light": "lightGreen"
    },
    "markdownLinkText": {
      "dark": "red",
      "light": "lightRed"
    },
    "markdownCode": {
      "dark": "green",
      "light": "lightGreen"
    },
    "markdownBlockQuote": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "markdownStrong": {
      "dark": "orange",
      "light": "lightOrange"
