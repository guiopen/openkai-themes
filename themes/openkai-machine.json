      "light": "lightGray"
    },
    "secondary": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "accent": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "error": {
      "dark": "red",
      "light": "lightRed"
    },
    "warning": {
      "dark": "orange",
      "light": "lightOrange"
    },
    "success": {
      "dark": "green",
      "light": "lightGreen"
    },
    "info": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "text": {
