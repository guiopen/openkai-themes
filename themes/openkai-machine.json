    "background": "#273136",
    "backgroundAlt": "#2d373c",
    "backgroundPanel": "#3a4449",
    "foreground": "#f2fffc",
    "comment": "#6b7678",
    "muted": "#8b9798",
    "dim": "#545f62",
    "gray": "#b8c4c3",
    "red": "#ff6d7e",
    "orange": "#ffb270",
    "yellow": "#ffed72",
    "green": "#a2e57b",
    "cyan": "#7cd5f1",
    "purple": "#baa0f8",
    "border": "#414b50",
    "borderFocus": "#6b7678",
    "borderSubtle": "#161b1e",
    "diffAddedBg": "#36473e",
    "diffRemovedBg": "#41383f",
    "lightBackground": "#faf4f2",
    "lightBackgroundAlt": "#f2edeb",
    "lightBackgroundPanel": "#e0dad9",
    "lightForeground": "#29242a",
    "lightComment": "#a59fa0",
