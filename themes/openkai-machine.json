      "dark": "comment",
      "light": "lightComment"
    },
    "syntaxKeyword": {
      "dark": "red",
      "light": "lightRed"
    },
    "syntaxFunction": {
      "dark": "green",
      "light": "lightGreen"
    },
    "syntaxVariable": {
      "dark": "foreground",
      "light": "lightForeground"
    },
    "syntaxString": {
      "dark": "yellow",
      "light": "lightYellow"
    },
    "syntaxNumber": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "syntaxType": {
      "dark": "cyan",
      "light": "lightCyan"
    },
    "syntaxOperator": {
      "dark": "red",
      "light": "lightRed"
    },
    "syntaxPunctuation": {
      "dark": "muted",
      "light": "lightMuted"
    }
